SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
APP_ENV=development
FAISS_INDEX_DIRECTORY=storage/faiss
CHAT_HISTORY_DB_PATH=storage/chat_history.sqlite3
UPLOADS_DIRECTORY=data/uploads
PROCESSED_DIRECTORY=data/processed
RETRIEVER_TOP_K=4
CHAT_HISTORY_MAX_MESSAGES=8
RETRIEVAL_HISTORY_USER_MESSAGES=3
PDF_MIN_TEXT_CHARS=120
PDF_GARBLED_CHAR_RATIO=0.35
MINERU_ENABLED=true
MINERU_DEFAULT_MODE=flash
MINERU_API_TOKEN=
MINERU_TIMEOUT_SECONDS=180
MINERU_SPLIT_PAGES=true
MINERU_LANGUAGE=ch
MINERU_DEFAULT_SENSITIVE=false
MINERU_SENSITIVE_NAME_PATTERNS=confidential,secret,internal,sensitive,机密,保密
MINERU_ALLOW_PRECISION_FALLBACK=true
